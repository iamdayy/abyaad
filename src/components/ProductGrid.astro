---
import { CldImage } from "astro-cloudinary";
import { getCldImageUrl } from "astro-cloudinary/helpers";
import { CirclePlay, ShoppingBag } from "lucide-react";
import productsData from "../data/products.json";

type ShopLink = {
  label: string;
  href: string;
  icon: "shoppingBag" | "circlePlay";
};

type ProductItem = {
  name: string;
  subtitle: string;
  category: string;
  price: string;
  cloudinaryPublicId: string;
  swatchKey: string;
};

type ProductsContent = {
  sectionId: string;
  title: string;
  description: string;
  exploreLabel: string;
  exploreHref: string;
  mainBadge: string;
  shopLinks: ShopLink[];
  items: ProductItem[];
};

const products = productsData as unknown as ProductsContent;

const iconMap: Record<ShopLink["icon"], typeof ShoppingBag> = {
  shoppingBag: ShoppingBag,
  circlePlay: CirclePlay,
};

const swatchMap: Record<string, string> = {
  white: "#f7f7f5",
  ivory: "#efe8da",
  black: "#1d1f24",
  mocca: "#8e6a4d",
  grey: "#9aa4af",
};

const getProductImageUrl = (publicId: string) =>
  getCldImageUrl({
    src: publicId,
    width: 1300,
    height: 1300,
    crop: "fill",
    gravity: "auto",
    quality: "auto",
    format: "auto",
  });

const productSchema = {
  "@context": "https://schema.org",
  "@type": "ItemList",
  name: products.title,
  description: products.description,
  numberOfItems: products.items.length,
  itemListElement: products.items.map((product, index) => ({
    "@type": "ListItem",
    position: index + 1,
    item: {
      "@type": "Product",
      name: product.name,
      description: `${product.subtitle} • ${product.category}`,
      category: product.category,
      image: getProductImageUrl(product.cloudinaryPublicId),
      brand: {
        "@type": "Brand",
        name: "Abyaad",
      },
      offers: {
        "@type": "Offer",
        priceCurrency: "USD",
        price: product.price.replace(/[^0-9.]/g, ""),
        availability: "https://schema.org/InStock",
      },
    },
  })),
};

const [mainProduct, ...secondaryProducts] = products.items;

const isExternalLink = (href: string) => /^https?:\/\//i.test(href);

const getLinkAttributes = (href: string) =>
  isExternalLink(href)
    ? {
        target: "_blank",
        rel: "noopener noreferrer",
      }
    : {
        target: undefined,
        rel: undefined,
      };
---

<section id={products.sectionId} class="section-shell py-16 md:py-20">
  <div class="mb-10 flex items-end justify-between gap-6">
    <div class="space-y-3">
      <h2 class="text-4xl leading-tight text-abyaad-ink sm:text-5xl">
        {products.title}
      </h2>
      <p class="text-sm leading-relaxed text-slate-500 sm:text-base">
        {products.description}
      </p>
    </div>
    <a
      href={products.exploreHref}
      {...getLinkAttributes(products.exploreHref)}
      class="hidden text-[0.65rem] uppercase tracking-[0.22em] text-slate-500 transition duration-300 hover:text-abyaad-navy md:block"
      data-cta="product-explore-all"
    >
      {products.exploreLabel}
    </a>
  </div>

  <div class="grid gap-4 lg:grid-cols-[1.35fr_1fr]">
    {
      mainProduct && (
        <article class="group overflow-hidden rounded-md border border-abyaad-line/80 bg-white shadow-sm transition duration-300 hover:-translate-y-0.5 hover:shadow-panel">
          <div class="relative h-[20rem] overflow-hidden sm:h-[24rem]">
            <CldImage
              src={mainProduct.cloudinaryPublicId}
              alt={mainProduct.name}
              width={1300}
              height={1300}
              crop="fill"
              gravity="auto"
              quality="auto"
              format="auto"
              class="h-full w-full object-cover transition duration-500 group-hover:scale-105"
              loading="lazy"
              decoding="async"
            />
            <span class="eyebrow absolute left-4 top-4">
              {products.mainBadge}
            </span>
          </div>
          <div class="flex items-end justify-between gap-4 px-5 py-5 sm:px-6">
            <div>
              <h3 class="font-display text-3xl leading-tight text-abyaad-ink">
                {mainProduct.name}
              </h3>
              <p class="mt-1 text-sm text-slate-500">{mainProduct.subtitle}</p>
              <div class="mt-3 flex items-center gap-2 text-[0.62rem] uppercase tracking-[0.2em] text-slate-500">
                <span
                  class="h-2.5 w-2.5 rounded-full border border-black/10"
                  style={`background-color: ${swatchMap[mainProduct.swatchKey] ?? "#d7dfe8"};`}
                />
                {mainProduct.category}
              </div>
            </div>
            <p class="text-sm font-medium text-abyaad-navy">
              {mainProduct.price}
            </p>
          </div>
        </article>
      )
    }

    <div class="grid gap-4 sm:grid-cols-2">
      {
        secondaryProducts.map((product) => (
          <article class="overflow-hidden rounded-md border border-abyaad-line/80 bg-white p-2 shadow-sm transition duration-300 hover:-translate-y-0.5 hover:shadow-panel">
            <div class="mb-4 h-40 overflow-hidden rounded-sm sm:h-44">
              <CldImage
                src={product.cloudinaryPublicId}
                alt={`${product.name} in ${product.subtitle}`}
                width={800}
                height={800}
                crop="fill"
                gravity="auto"
                quality="auto"
                format="auto"
                class="h-full w-full object-cover"
                loading="lazy"
                decoding="async"
              />
            </div>
            <div class="space-y-1 px-1 pb-2">
              <div class="flex items-center justify-between gap-3">
                <p class="text-[0.62rem] uppercase tracking-[0.22em] text-slate-500">
                  {product.category}
                </p>
                <span
                  class="h-2.5 w-2.5 rounded-full border border-black/10"
                  style={`background-color: ${swatchMap[product.swatchKey] ?? "#d7dfe8"};`}
                  aria-hidden="true"
                />
              </div>
              <div class="flex items-baseline justify-between gap-4">
                <h3 class="font-display text-lg leading-tight text-abyaad-ink">
                  {product.name}
                </h3>
                <p class="text-xs text-slate-600">{product.price}</p>
              </div>
              <p class="text-xs text-slate-500">{product.subtitle}</p>
            </div>
          </article>
        ))
      }
    </div>
  </div>

  <div class="mt-8 flex flex-wrap gap-2">
    {
      products.shopLinks.map((shop, index) => {
        const ShopIcon = iconMap[shop.icon];
        const buttonClass =
          index === 0
            ? "inline-flex items-center gap-2 rounded-md bg-abyaad-navy px-4 py-2 text-[0.62rem] font-medium uppercase tracking-[0.18em] text-white transition duration-300 hover:bg-abyaad-blue hover:text-abyaad-navy"
            : "inline-flex items-center gap-2 rounded-md border border-abyaad-line bg-white px-4 py-2 text-[0.62rem] font-medium uppercase tracking-[0.18em] text-slate-700 transition duration-300 hover:border-abyaad-navy hover:text-abyaad-navy";

        return (
          <a
            href={shop.href}
            {...getLinkAttributes(shop.href)}
            class={buttonClass}
            aria-label={`Belanja di ${shop.label}`}
            data-cta={`product-${shop.label.toLowerCase().replace(/\s+/g, "-")}`}
          >
            {ShopIcon && <ShopIcon size={14} />}
            {shop.label}
          </a>
        );
      })
    }
    <a
      href="#ukuran"
      class="inline-flex items-center gap-2 rounded-md border border-abyaad-line bg-white px-4 py-2 text-[0.62rem] font-medium uppercase tracking-[0.18em] text-slate-700 transition duration-300 hover:border-abyaad-navy hover:text-abyaad-navy"
      data-cta="product-size-guide"
    >
      Size Guide
    </a>
  </div>

  <script
    is:inline
    type="application/ld+json"
    set:html={JSON.stringify(productSchema)}
  />
</section>
