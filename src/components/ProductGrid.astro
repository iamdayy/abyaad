---
import { ShoppingBag, CirclePlay } from 'lucide-react';

const products = [
  { name: 'Ivory', swatch: 'bg-abyaad-ivory' },
  { name: 'Black', swatch: 'bg-black' },
  { name: 'Mocca', swatch: 'bg-abyaad-mocca' },
  { name: 'Grey', swatch: 'bg-abyaad-stone' },
  { name: 'White', swatch: 'bg-white border border-slate-200' }
];
---

<section id="produk" class="mx-auto w-full max-w-6xl px-4 py-16 sm:px-6 lg:px-8">
  <div class="mb-10 space-y-3">
    <h2 class="text-2xl font-semibold text-abyaad-navy sm:text-3xl">Pilih Warna Favoritmu</h2>
    <p class="text-sm leading-relaxed text-abyaad-stone sm:text-base">Semua varian tersedia dengan harga sama: <span class="font-semibold text-abyaad-navy">Rp 89.000</span>.</p>
  </div>

  <div class="grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
    {products.map((product) => (
      <article class="flex flex-col rounded-2xl border border-slate-100 bg-white p-5 shadow-sm transition duration-300 hover:-translate-y-1 hover:shadow-md">
        <div class={`mb-4 h-32 rounded-xl ${product.swatch}`}></div>
        <h3 class="text-lg font-semibold text-abyaad-navy">Loose Pants - {product.name}</h3>
        <p class="mt-1 text-sm text-abyaad-stone">Highwaist pleated fit, look clean dan nyaman dipakai.</p>
        <p class="mt-3 text-base font-semibold text-abyaad-navy">Rp 89.000</p>
        <div class="mt-4 flex flex-wrap gap-2">
          <a
            href="#"
            class="inline-flex items-center gap-2 rounded-full bg-abyaad-blue px-4 py-2 text-xs font-medium text-abyaad-navy transition duration-300 hover:bg-abyaad-navy hover:text-white"
          >
            <ShoppingBag size={14} />
            Shopee
          </a>
          <a
            href="#"
            class="inline-flex items-center gap-2 rounded-full border border-abyaad-navy px-4 py-2 text-xs font-medium text-abyaad-navy transition duration-300 hover:bg-abyaad-navy hover:text-white"
          >
            <CirclePlay size={14} />
            TikTok Shop
          </a>
        </div>
      </article>
    ))}
  </div>
</section>
