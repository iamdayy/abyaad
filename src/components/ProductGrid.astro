---
import { ShoppingBag, CirclePlay } from 'lucide-react';
import productsData from '../data/products.json';

const iconMap = {
  shoppingBag: ShoppingBag,
  circlePlay: CirclePlay
};

const swatchClassMap = {
  ivory: 'bg-abyaad-ivory',
  black: 'bg-black',
  mocca: 'bg-abyaad-mocca',
  grey: 'bg-abyaad-stone',
  white: 'bg-white border border-slate-200'
};
---

<section id={productsData.sectionId} class="mx-auto w-full max-w-6xl px-4 py-16 sm:px-6 lg:px-8">
  <div class="mb-10 space-y-3">
    <h2 class="text-2xl font-semibold text-abyaad-navy sm:text-3xl">{productsData.title}</h2>
    <p class="text-sm leading-relaxed text-abyaad-stone sm:text-base">{productsData.description} <span class="font-semibold text-abyaad-navy">{productsData.price}</span>.</p>
  </div>

  <div class="grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
    {productsData.items.map((product) => (
      <article class="flex flex-col rounded-2xl border border-slate-100 bg-white p-5 shadow-sm transition duration-300 hover:-translate-y-1 hover:shadow-md">
        <div class={`mb-4 h-32 rounded-xl ${swatchClassMap[product.swatchKey] ?? ''}`}></div>
        <h3 class="text-lg font-semibold text-abyaad-navy">{productsData.cardTitlePrefix} - {product.name}</h3>
        <p class="mt-1 text-sm text-abyaad-stone">{productsData.cardDescription}</p>
        <p class="mt-3 text-base font-semibold text-abyaad-navy">{productsData.price}</p>
        <div class="mt-4 flex flex-wrap gap-2">
          {productsData.shopLinks.map((shop, index) => {
            const ShopIcon = iconMap[shop.icon];
            const buttonClass = index === 0
              ? 'inline-flex items-center gap-2 rounded-full bg-abyaad-blue px-4 py-2 text-xs font-medium text-abyaad-navy transition duration-300 hover:bg-abyaad-navy hover:text-white'
              : 'inline-flex items-center gap-2 rounded-full border border-abyaad-navy px-4 py-2 text-xs font-medium text-abyaad-navy transition duration-300 hover:bg-abyaad-navy hover:text-white';

            return (
              <a href={shop.href} class={buttonClass}>
                {ShopIcon && <ShopIcon size={14} />}
                {shop.label}
              </a>
            );
          })}
        </div>
      </article>
    ))}
  </div>
</section>
