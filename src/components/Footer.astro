---
import { Camera, MessageCircle, MapPin } from 'lucide-react';
---

<footer class="border-t border-slate-100 bg-white">
  <div class="mx-auto flex w-full max-w-6xl flex-col gap-6 px-4 py-10 sm:px-6 sm:py-12 lg:flex-row lg:items-center lg:justify-between lg:px-8">
    <div>
      <p class="text-lg font-semibold text-abyaad-navy">Abyaad</p>
      <p class="mt-2 text-sm text-abyaad-stone">Essential Basic Wear.</p>
      <p class="mt-1 inline-flex items-center gap-2 text-sm text-abyaad-stone">
        <MapPin size={14} />
        Pekalongan, Indonesia
      </p>
    </div>

    <div class="flex flex-wrap items-center gap-5 text-sm text-abyaad-stone">
      <a href="#produk" class="transition duration-300 hover:text-abyaad-navy">Produk</a>
      <a href="#ukuran" class="transition duration-300 hover:text-abyaad-navy">Ukuran</a>
      <a href="#cerita" class="transition duration-300 hover:text-abyaad-navy">Cerita</a>
      <a href="#" class="inline-flex items-center gap-1 transition duration-300 hover:text-abyaad-navy"><Camera size={14} /> Instagram</a>
      <a href="#" class="inline-flex items-center gap-1 transition duration-300 hover:text-abyaad-navy"><MessageCircle size={14} /> WhatsApp</a>
    </div>
  </div>
</footer>
