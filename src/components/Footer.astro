---
import footerData from "../data/footer.json";
---

<footer class="border-t border-abyaad-line/80 bg-transparent">
  <div
    class="section-shell flex flex-col gap-6 py-12 text-[0.65rem] uppercase tracking-[0.18em] text-slate-500 lg:flex-row lg:items-center lg:justify-between"
  >
    <div class="space-y-2">
      <p
        class="font-display text-lg normal-case tracking-normal text-abyaad-ink"
      >
        {footerData.brand}
      </p>
      <p
        class="max-w-xs text-[0.58rem] leading-relaxed tracking-[0.12em] text-slate-400"
      >
        Editorial essentials, built for daily wear and long-term rotation.
      </p>
    </div>
    <div class="flex flex-wrap gap-5">
      {
        footerData.links.map((link) => (
          <a
            href={link.href}
            class="transition duration-300 hover:text-abyaad-ink"
          >
            {link.label}
          </a>
        ))
      }
    </div>
    <p
      class="max-w-xs text-[0.58rem] leading-relaxed tracking-[0.12em] text-slate-400"
    >
      {footerData.copyright}
    </p>
  </div>
</footer>
