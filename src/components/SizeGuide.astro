---
import sizeGuideData from "../data/size-guide.json";
---

<section id={sizeGuideData.sectionId} class="section-shell py-16 md:py-20">
  <div
    class="grid gap-6 rounded-md border border-abyaad-line/70 bg-white p-7 shadow-sm md:grid-cols-[0.8fr_1.2fr] md:items-start md:p-10"
  >
    <div class="space-y-4">
      <p class="eyebrow">Fit reference</p>
      <h2 class="text-4xl leading-[0.95] text-abyaad-ink sm:text-5xl">
        {sizeGuideData.title}
      </h2>
      <p class="max-w-md text-sm leading-relaxed text-slate-600 sm:text-base">
        {sizeGuideData.description}
      </p>
    </div>

    <div class="overflow-hidden rounded-sm border border-abyaad-line/60">
      <table class="w-full text-left text-sm">
        <thead class="bg-abyaad-mist/70">
          <tr class="border-b border-abyaad-line/60">
            {
              sizeGuideData.columns.map((column) => (
                <th class="px-5 py-4 text-[0.62rem] font-medium uppercase tracking-[0.2em] text-slate-500">
                  {column}
                </th>
              ))
            }
          </tr>
        </thead>
        <tbody>
          {
            sizeGuideData.rows.map((row, index) => (
              <tr
                class={
                  index !== sizeGuideData.rows.length - 1
                    ? "border-b border-abyaad-line/60"
                    : ""
                }
              >
                <td class="px-5 py-4 font-display text-lg text-abyaad-ink">
                  {row.category}
                </td>
                <td class="px-5 py-4 text-slate-600">{row.weightRange}</td>
                <td class="px-5 py-4 text-slate-600">{row.description}</td>
              </tr>
            ))
          }
        </tbody>
      </table>
    </div>
  </div>
</section>
