---
import sizeGuideData from '../data/size-guide.json';
---

<section id={sizeGuideData.sectionId} class="bg-slate-50/70 py-16">
  <div class="mx-auto w-full max-w-6xl px-4 sm:px-6 lg:px-8">
    <div class="mb-8 space-y-3">
      <h2 class="text-2xl font-semibold text-abyaad-navy sm:text-3xl">{sizeGuideData.title}</h2>
      <p class="text-sm text-abyaad-stone sm:text-base">{sizeGuideData.description}</p>
    </div>

    <div class="overflow-hidden rounded-2xl border border-slate-100 bg-white shadow-sm">
      <table class="w-full text-left text-sm">
        <thead class="bg-white">
          <tr class="border-b border-slate-100">
            {sizeGuideData.columns.map((column) => (
              <th class="px-5 py-4 font-semibold text-abyaad-navy">{column}</th>
            ))}
          </tr>
        </thead>
        <tbody>
          {sizeGuideData.rows.map((row, index) => (
            <tr class={index !== sizeGuideData.rows.length - 1 ? 'border-b border-slate-100' : ''}>
              <td class="px-5 py-4 font-medium text-abyaad-navy">{row.category}</td>
              <td class="px-5 py-4 text-abyaad-stone">{row.weightRange}</td>
              <td class="px-5 py-4 text-abyaad-stone">{row.description}</td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  </div>
</section>
