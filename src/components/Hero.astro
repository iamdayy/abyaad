---
import heroData from '../data/hero.json';
---

<section class="mx-auto grid w-full max-w-6xl gap-8 px-4 py-16 sm:px-6 md:grid-cols-2 md:items-center md:py-24 lg:px-8">
  <div class="space-y-6">
    <p class="text-sm font-semibold uppercase tracking-[0.2em] text-abyaad-blue">{heroData.badge}</p>
    <h1 class="text-3xl font-semibold leading-tight text-abyaad-navy sm:text-4xl lg:text-5xl">{heroData.title}</h1>
    <p class="max-w-xl text-base leading-relaxed text-abyaad-stone sm:text-lg">
      {heroData.description}
    </p>
    <a
      href={heroData.ctaTarget}
      class="inline-flex items-center rounded-full bg-abyaad-navy px-6 py-3 text-sm font-medium text-white transition duration-300 hover:bg-abyaad-blue hover:text-abyaad-navy"
    >
      {heroData.ctaLabel}
    </a>
  </div>
  <div class="rounded-3xl bg-gradient-to-br from-abyaad-blue/25 via-white to-abyaad-ivory/40 p-8 sm:p-10">
    <div class="space-y-4 rounded-2xl border border-white/80 bg-white/80 p-6 shadow-sm backdrop-blur">
      <p class="text-sm font-medium text-abyaad-stone">{heroData.featuredLabel}</p>
      <h2 class="text-2xl font-semibold text-abyaad-navy">{heroData.featuredTitle}</h2>
      <p class="text-sm leading-relaxed text-abyaad-stone">{heroData.featuredDescription}</p>
    </div>
  </div>
</section>
