<section
  id="newsletter"
  class="border-y border-abyaad-line/70 bg-white/65 py-16 md:py-20"
>
  <div class="section-shell text-center">
    <p
      class="mx-auto mb-6 w-fit border-b border-abyaad-line pb-2 text-[0.62rem] uppercase tracking-[0.28em] text-slate-500"
    >
      Stay Connected
    </p>
    <h2 class="text-4xl leading-tight text-abyaad-ink sm:text-5xl">
      Join the Essential Circle
    </h2>
    <p
      class="mx-auto mt-3 max-w-xl text-sm leading-relaxed text-slate-600 sm:text-base"
    >
      Receive early access to drops, editorial lookbooks, and limited restocks.
    </p>

    <form class="mx-auto mt-8 flex max-w-xl flex-col gap-3 sm:flex-row">
      <label for="email" class="sr-only">Email</label>
      <input
        id="email"
        type="email"
        name="email"
        placeholder="Enter your email"
        autocomplete="email"
        class="w-full border border-abyaad-line bg-white px-4 py-3 text-xs uppercase tracking-[0.14em] text-abyaad-ink placeholder:text-slate-400 focus:border-abyaad-navy focus:outline-none"
      />
      <button
        type="submit"
        class="rounded-sm bg-abyaad-ink px-8 py-3 text-[0.66rem] font-medium uppercase tracking-[0.2em] text-white transition duration-300 hover:bg-abyaad-navy"
      >
        Subscribe
      </button>
    </form>
    <p
      class="mx-auto mt-4 max-w-lg text-[0.68rem] uppercase tracking-[0.16em] text-slate-400"
    >
      No spam, only early access, lookbooks, and release updates.
    </p>
    <p
      class="mx-auto mt-2 text-[0.58rem] uppercase tracking-[0.14em] text-slate-400"
    >
      Privacy protected • Unsubscribe kapan saja.
    </p>
  </div>
</section>
