---
import '@fontsource/inter/400.css';
import '@fontsource/inter/500.css';
import '@fontsource/inter/600.css';
import '@fontsource/inter/700.css';
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Abyaad | Essential Basic Wear',
  description = 'Abyaad menghadirkan loose pants highwaist pleated yang nyaman, ringan, dan dibuat dengan sentuhan craftsmanship Pekalongan.'
} = Astro.props;
const canonicalUrl = new URL(Astro.url.pathname, Astro.site);
const image = '/og-abyaad.jpg';
---

<!doctype html>
<html lang="id">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="keywords" content="Abyaad, Essential Basic Wear, Loose Pants, Highwaist Pleated, Pekalongan" />
    <meta name="author" content="Abyaad" />
    <meta name="robots" content="index, follow" />
    <link rel="canonical" href={canonicalUrl} />

    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Abyaad" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={new URL(image, Astro.site)} />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={new URL(image, Astro.site)} />
    <meta name="theme-color" content="#82C9F9" />
  </head>
  <body>
    <header class="sticky top-0 z-30 border-b border-slate-100/80 bg-white/90 backdrop-blur">
      <nav class="mx-auto flex w-full max-w-6xl items-center justify-between px-4 py-4 sm:px-6 lg:px-8">
        <a href="#" class="text-lg font-semibold tracking-tight text-abyaad-navy transition duration-300 hover:text-abyaad-blue">Abyaad</a>
        <div class="flex items-center gap-5 text-sm font-medium text-abyaad-stone">
          <a href="#produk" class="transition duration-300 hover:text-abyaad-navy">Produk</a>
          <a href="#ukuran" class="transition duration-300 hover:text-abyaad-navy">Ukuran</a>
          <a href="#cerita" class="transition duration-300 hover:text-abyaad-navy">Cerita</a>
        </div>
      </nav>
    </header>
    <main>
      <slot />
    </main>
  </body>
</html>
