---
import Layout from "../layouts/Layout.astro";
---

<Layout
  title="Contact Us | Abyaad"
  description="Hubungi Abyaad untuk pertanyaan produk, kolaborasi, dan dukungan pelanggan."
>
  <section class="section-shell py-16 md:py-20">
    <div
      class="max-w-3xl space-y-6 rounded-md border border-abyaad-line/70 bg-white p-7 shadow-sm md:p-10"
    >
      <p class="eyebrow">Contact Us</p>
      <h1 class="text-4xl leading-tight text-abyaad-ink sm:text-5xl">
        Terhubung dengan Tim Abyaad
      </h1>
      <p class="text-sm leading-relaxed text-slate-600 sm:text-base">
        Untuk pertanyaan produk, kolaborasi, atau bantuan pesanan, silakan
        hubungi kami melalui email berikut.
      </p>
      <p class="text-base text-abyaad-navy">
        <a
          href="mailto:hello@abyaad.id"
          class="underline decoration-abyaad-line underline-offset-4 transition hover:text-abyaad-ink"
        >
          hello@abyaad.id
        </a>
      </p>
      <p class="text-sm leading-relaxed text-slate-600 sm:text-base">
        Tim kami akan merespons secepat mungkin pada hari kerja.
      </p>
      <p class="text-xs uppercase tracking-[0.16em] text-slate-400">
        Support hours: Monday-Saturday, 09:00-18:00 WIB
      </p>
    </div>
  </section>
</Layout>
